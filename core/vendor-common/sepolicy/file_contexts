# Label the Nowhere binaries (entrypoints for the nowhere domain) and the ephemeral state dir.
/system/bin/nowhere_agent           u:object_r:nowhere_exec:s0
/system/bin/nowhere_login\.sh       u:object_r:nowhere_exec:s0
/data/nowhere(/.*)?                 u:object_r:nowhere_data_file:s0
# The init-created blind-login socket. The .rc seclabel labels the socket OBJECT; this labels the
# /dev/socket FILE so the chooser's unix_socket_connect sock_file-write applies (like /dev/socket/lmkd).
/dev/socket/nowhere_login           u:object_r:nowhere_login_socket:s0

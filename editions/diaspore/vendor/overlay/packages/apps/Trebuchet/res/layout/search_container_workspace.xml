<?xml version="1.0" encoding="utf-8"?>
<!--
  Diaspore (DIA-20260618-01): empty first-page QSB container. The Diaspore home keeps an intentionally
  EMPTY landing page (wallpaper + dock); QSB_ON_FIRST_SCREEN is turned on (Trebuchet BuildConfig) ONLY so
  Launcher3 creates that leading page instead of collapsing the apps onto it. We do NOT want the (no-GApps,
  dead) Google search bar, so this overlay drops the QsbFragment and leaves a zero-height, invisible
  QsbContainerView. Same root type + id the binder expects (R.id.search_container_workspace), so nothing
  NPEs; it just renders nothing.
-->
<com.android.launcher3.qsb.QsbContainerView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@id/search_container_workspace"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:padding="0dp" />
